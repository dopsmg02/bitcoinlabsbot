generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String        @id
  telegramUsername   String?
  isPremium          Boolean       @default(false)
  role               Role          @default(USER)
  btclBalance        Decimal       @default(0) @db.Decimal(18, 2)
  tierLevel          Int           @default(1)
  totalDeposit       Decimal       @default(0) @db.Decimal(18, 2)
  totalWithdraw      Decimal       @default(0) @db.Decimal(18, 2)
  totalReferralBonus Decimal       @default(0) @db.Decimal(18, 2)
  isBanned           Boolean       @default(false)
  lastLoginIp        String?
  referrerId         String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  luckySpinTickets   Int           @default(0)
  deposits           Deposit[]
  investments        Investment[]
  transactions       Transaction[]
  referrer           User?         @relation("UserToReferrer", fields: [referrerId], references: [id])
  downlines          User[]        @relation("UserToReferrer")
  withdrawals        Withdrawal[]

  @@index([referrerId])
  @@index([btclBalance(sort: Desc)])
}

model Plan {
  id              String       @id @default(uuid())
  name            String
  minAmount       Decimal      @db.Decimal(18, 2)
  maxAmount       Decimal      @db.Decimal(18, 2)
  dailyRoiPercent Decimal      @db.Decimal(5, 2)
  durationDays    Int
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  investments     Investment[]
}

model Investment {
  id          String           @id @default(uuid())
  userId      String
  planId      String
  amount      Decimal          @db.Decimal(18, 2)
  dailyRoi    Decimal          @db.Decimal(18, 2)
  totalEarned Decimal          @default(0) @db.Decimal(18, 2)
  lastRoiAt   DateTime         @default(now())
  startDate   DateTime         @default(now())
  endDate     DateTime
  status      InvestmentStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  plan        Plan             @relation(fields: [planId], references: [id])
  user        User             @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

model Deposit {
  id          String        @id @default(uuid())
  userId      String
  amount      Decimal       @db.Decimal(18, 2)
  currency    String        @default("USDT_BEP20")
  txnId       String?       @unique
  address     String?
  status      DepositStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  completedAt DateTime?
  user        User          @relation(fields: [userId], references: [id])

  @@index([userId, txnId])
}

model Withdrawal {
  id            String         @id @default(uuid())
  userId        String
  amount        Decimal        @db.Decimal(18, 2)
  fee           Decimal        @db.Decimal(18, 2)
  netAmount     Decimal        @db.Decimal(18, 2)
  walletAddress String
  status        WithdrawStatus @default(PENDING)
  createdAt     DateTime       @default(now())
  processedAt   DateTime?
  user          User           @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String
  type        TxType
  amount      Decimal  @db.Decimal(18, 2)
  description String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, type])
}

model Announcement {
  id        String   @id @default(uuid())
  text      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SystemConfig {
  id              String   @id @default("GLOBAL")
  maintenanceMode Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum InvestmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum DepositStatus {
  PENDING
  CONFIRMED
  COMPLETED
  EXPIRED
  CANCELLED
  ERROR
}

enum WithdrawStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  FAILED
}

enum TxType {
  DEPOSIT
  WITHDRAW
  INVESTMENT
  ROI_DAILY
  REFERRAL_LEVEL_1
  REFERRAL_LEVEL_2
  REFERRAL_LEVEL_3
  REFERRAL_LEVEL_4
  REFERRAL_LEVEL_5
  BONUS_BOUNTY
  LUCKY_SPIN
}
