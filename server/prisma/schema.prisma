// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

model User {
  id                    String        @id // Telegram ID
  telegramUsername      String?
  isPremium             Boolean       @default(false)
  role                  Role          @default(USER)
  
  // Balances
  balance               Decimal       @default(0) @db.Decimal(18, 2)
  totalDeposit          Decimal       @default(0) @db.Decimal(18, 2)
  totalWithdraw         Decimal       @default(0) @db.Decimal(18, 2)
  totalReferralBonus    Decimal       @default(0) @db.Decimal(18, 2)
  
  // Anti-Cheat & Security
  isBanned              Boolean       @default(false)
  lastLoginIp           String?       

  // Referral System (Self-relation)
  referrerId            String?       
  referrer              User?         @relation("UserToReferrer", fields: [referrerId], references: [id])
  downlines             User[]        @relation("UserToReferrer")

  // Timestamps
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  // Data Relations
  investments           Investment[]
  deposits              Deposit[]
  withdrawals           Withdrawal[]
  transactions          Transaction[]
  luckySpinTickets      Int           @default(0)

  @@index([referrerId])
  @@index([balance(sort: Desc)])
}

model Plan {
  id              String   @id @default(uuid())
  name            String   // e.g., "Silver", "Gold", "VIP"
  minAmount       Decimal  @db.Decimal(18, 2)
  maxAmount       Decimal  @db.Decimal(18, 2)
  dailyRoiPercent Decimal  @db.Decimal(5, 2) // e.g., 2.00%
  durationDays    Int      // e.g., 30
  active          Boolean  @default(true)
  investments     Investment[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Investment {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  planId          String
  plan            Plan     @relation(fields: [planId], references: [id])
  
  amount          Decimal  @db.Decimal(18, 2)
  dailyRoi        Decimal  @db.Decimal(18, 2) // Cached daily profit amount
  
  totalEarned     Decimal  @default(0) @db.Decimal(18, 2)
  lastRoiAt       DateTime @default(now()) // For daily profit distribution
  
  startDate       DateTime @default(now())
  endDate         DateTime
  
  status          InvestmentStatus @default(ACTIVE)

  createdAt       DateTime @default(now())

  @@index([userId, status])
}

model Deposit {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  amount          Decimal  @db.Decimal(18, 2)
  currency        String   @default("USDT_BEP20")
  
  // Plisio specific fields
  txnId           String?  @unique // Plisio ID
  address         String?  // Generated address
  status          DepositStatus @default(PENDING)
  
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  @@index([userId, txnId])
}

model Withdrawal {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  amount          Decimal  @db.Decimal(18, 2)
  fee             Decimal  @db.Decimal(18, 2)
  netAmount       Decimal  @db.Decimal(18, 2)
  
  walletAddress   String
  status          WithdrawStatus @default(PENDING)
  
  createdAt       DateTime @default(now())
  processedAt     DateTime?

  @@index([userId, createdAt])
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  type        TxType
  amount      Decimal  @db.Decimal(18, 2)
  description String?
  
  createdAt   DateTime @default(now())

  @@index([userId, type])
}

enum InvestmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum DepositStatus {
  PENDING
  CONFIRMED
  COMPLETED
  EXPIRED
  CANCELLED
  ERROR
}

enum WithdrawStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  FAILED
}

enum TxType {
  DEPOSIT
  WITHDRAW
  INVESTMENT
  ROI_DAILY
  REFERRAL_LEVEL_1
  REFERRAL_LEVEL_2
  REFERRAL_LEVEL_3
  REFERRAL_LEVEL_4
  REFERRAL_LEVEL_5
  BONUS_BOUNTY
  LUCKY_SPIN
}

model Announcement {
  id        String   @id @default(uuid())
  text      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SystemConfig {
  id              String   @id @default("GLOBAL")
  maintenanceMode Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}
